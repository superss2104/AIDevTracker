# Copy this file to .env and fill in your values.
# Never commit your actual .env file — it contains secret keys.

GEMINI_API_KEY=your_gemini_api_key_here

# Relevance threshold for AI contribution scoring (0.0 to 1.0).
# Default: 0.4 — prompts with similarity >= threshold are marked as AI-relevant.
# Can be overridden at runtime: python main.py --threshold 0.6 analyze
RELEVANCE_THRESHOLD=0.4
