# Copy this file to .env and fill in your values.
# Never commit your actual .env file — it contains secret keys.
#
# You can set the LLM configuration in three ways:
#   1. Edit this file directly
#   2. On first run, you will be prompted to select a provider interactively
#   3. At any time: python main.py model <API_KEY> --base-url <URL> --model <MODEL>

LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash

# Relevance threshold for AI contribution scoring (0.0 to 1.0).
# Default: 0.4 — prompts with similarity >= threshold are marked as AI-relevant.
# Can be overridden at runtime: python main.py --threshold 0.6 analyze
RELEVANCE_THRESHOLD=0.4
